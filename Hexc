-- Versi: 2026 Anti-Method 0x3

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")

local kickBlocked = 0
local skillFired = 0
local afkBlocked = 0

local antiKick = true
local skillBypass = true
local antiAfk = true

-- ==================== ANTI-KICK (Method 0x3 Bypass) ====================

local function BlockKick(...)
    kickBlocked += 1
    return nil
end

-- Direct Override (Paling Aman)
LocalPlayer.Kick = BlockKick

-- Hook hanya di LocalPlayer (bukan di game)
local OldPlayerNamecall
OldPlayerNamecall = hookmetamethod(LocalPlayer, "__namecall", function(self, ...)
    if not antiKick then return OldPlayerNamecall(self, ...) end
    
    local Method = getnamecallmethod()
    
    if Method == "Kick" or Method == "kick" then
        return BlockKick()
    end
    
    return OldPlayerNamecall(self, ...)
end)

-- Skill Bypass (Hanya hook remote tertentu, bukan semua FireServer)
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if skillBypass and Method == "FireServer" then
        local name = tostring(self):lower()
        if name:find("skill") or name:find("attack") or name:find("ability") or name:find("action") then
            skillFired += 1
            task.spawn(function()
                task.wait(0.105 + math.random(3,12)/100)
                return OldNamecall(self, unpack(Args))
            end)
            return nil
        end
    end

    return OldNamecall(self, ...)
end)

-- Anti AFK
LocalPlayer.Idled:Connect(function()
    if antiAfk then
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
        afkBlocked += 1
    end
end)

print("Core System Loaded - Method 0x3 Protection Active")
