-- ==================== STEALTH HOOK ====================

local hookmetamethod = hookmetamethod or (syn and syn.hookmetamethod)

local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    -- Anti Kick
    if antiKick and (Method == "Kick" or Method == "kick") then
        kickBlocked += 1
        return nil
    end

    -- Skill Bypass (Randomized Timing)
    if skillBypass and Method == "FireServer" then
        local lowered = tostring(self):lower()
        if lowered:find("skill") or lowered:find("attack") or lowered:find("ability") or lowered:find("action") then
            skillFired += 1
            
            task.spawn(function()
                local delay = 0.12 + math.random(1, 9) / 100  -- 0.12 - 0.21 detik (lebih natural)
                task.wait(delay)
                return OldNamecall(self, unpack(Args))
            end)
            return nil
        end
    end

    return OldNamecall(self, ...)
end)

