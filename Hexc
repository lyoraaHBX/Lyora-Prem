local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local VirtualUser = game:GetService("VirtualUser")

local kickBlocked = 0
local skillFired = 0
local afkBlocked = 0

local antiKick = true
local skillBypass = true
local antiAfk = true

-- ==================== ENHANCED ANTI-KICK ====================

local function BlockKick(...)
    kickBlocked += 1
    -- warn("Kick attempt blocked")
    return nil
end

-- Layer 1: Hook global Namecall
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if antiKick and (Method == "Kick" or Method == "kick") then
        return BlockKick()
    end

    -- Skill Bypass dengan random delay
    if skillBypass and Method == "FireServer" then
        local lowered = tostring(self):lower()
        if lowered:find("skill") or lowered:find("attack") or lowered:find("ability") then
            skillFired += 1
            task.spawn(function()
                task.wait(0.11 + math.random(1,11)/100)
                return OldNamecall(self, unpack(Args))
            end)
            return nil
        end
    end

    return OldNamecall(self, ...)
end)

-- Layer 2: Direct Kick Override (Paling Penting)
LocalPlayer.Kick = BlockKick

-- Layer 3: Metatable Player Protection
local playerMT = getrawmetatable(LocalPlayer)
if playerMT then
    local oldPlayerNC
    oldPlayerNC = hookmetamethod(LocalPlayer, "__namecall", function(self, ...)
        if getnamecallmethod() == "Kick" then
            return BlockKick()
        end
        return oldPlayerNC(self, ...)
    end)
end

-- Extra Protection
LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(1)
    if char:FindFirstChild("Humanoid") then
        char.Humanoid.Died:Connect(function()
            -- Beberapa server kick lewat death
        end)
    end
end)

-- ==================== ANTI-AFK ====================
