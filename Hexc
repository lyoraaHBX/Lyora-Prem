-- ==================== CORE SCRIPT ====================

local kickBlocked = 0
local skillFired = 0
local afkBlocked = 0
local isActive = true
local antiAfkActive = true
local antiKickActive = true
local skillBypassActive = true

MT.__namecall = newcclosure(function(self, ...)
    local Method = getnamecallmethod()
    local Args = {...}

    if antiKickActive and (Method == "Kick" or Method == "kick") then
        kickBlocked = kickBlocked + 1
        warn("Sistem mencoba Kick, tapi diblokir!")
        return nil
    end

    if skillBypassActive and Method == "FireServer" and (tostring(self):lower():find("skill") or tostring(self):lower():find("attack")) then
        task.spawn(function()
            task.wait(0.2)
            return OldNC(self, unpack(Args))
        end)
        skillFired = skillFired + 1
        return nil
    end

    return OldNC(self, ...)
end)
setreadonly(MT, true)

Player.Idled:Connect(function()
    if antiAfkActive then
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton2(Vector2.new())
        afkBlocked = afkBlocked + 1
    end
end)

