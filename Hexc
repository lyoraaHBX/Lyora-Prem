-- ═══════════════════════════════════════════
--              HELPERS
-- ═══════════════════════════════════════════

local function GetWeaponName(character)
    if not character then return nil end
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") and table.find(WeaponList, tool.Name) then
            return tool.Name
        end
    end
    return nil
end

local function IsSeeker(player)
    local v = player:FindFirstChild("IsSeeker")
    return v and v:IsA("BoolValue") and v.Value
end

local function GetHumanoid(player)
    local char = player.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

-- ═══════════════════════════════════════════
--              ESP CORE
-- ═══════════════════════════════════════════

local function CleanESP(player)
    local name = player.Name
    if ESPConnections[name] then
        for _, c in pairs(ESPConnections[name]) do
            pcall(function() c:Disconnect() end)
        end
        ESPConnections[name] = nil
    end
    if ESPObjects[name] then
        for _, obj in pairs(ESPObjects[name]) do
            pcall(function() obj:Destroy() end)
        end
        ESPObjects[name] = nil
    end
end

local function CreateESP(player)
    if player == LocalPlayer then return end
    CleanESP(player)
    if not State.ESP then return end

    local function applyToChar(character)
        CleanESP(player)
        if not State.ESP then return end

        local conns = {}
        local objs  = {}

        -- Highlight (Chams)
        local ok, Head = pcall(function()
            return character:WaitForChild("Head", 5)
        end)
        if not ok or not Head then return end

        local Highlight = Instance.new("Highlight")
        Highlight.Adornee             = character
        Highlight.FillColor           = Color3.fromRGB(255, 0, 100)
        Highlight.OutlineColor        = Color3.fromRGB(255, 255, 255)
        Highlight.FillTransparency    = 0.5
        Highlight.OutlineTransparency = 0
        Highlight.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
        Highlight.Parent              = character
        table.insert(objs, Highlight)

        -- BillboardGui
        local Billboard = Instance.new("BillboardGui")
        Billboard.Adornee     = Head
        Billboard.AlwaysOnTop = true
        Billboard.Size        = UDim2.new(0, 200, 0, 60)
        Billboard.StudsOffset = Vector3.new(0, 3.5, 0)
        Billboard.MaxDistance = 1000
        Billboard.Parent      = character
        table.insert(objs, Billboard)

        -- Line Frame (ESP Line)
        local LineGui = Instance.new("ScreenGui")
        LineGui.Name          = "ESPLine_"..player.Name
        LineGui.ResetOnSpawn  = false
        LineGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        pcall(function()
            LineGui.Parent = game:GetService("CoreGui")
        end)
        table.insert(objs, LineGui)

        local LineFrame = Instance.new("Frame")
        LineFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 0)
        LineFrame.BorderSizePixel  = 0
        LineFrame.AnchorPoint      = Vector2.new(0.5, 0)
        LineFrame.Parent           = LineGui
        table.insert(objs, LineFrame)

        -- TextLabel
        local TextLabel = Instance.new("TextLabel")
        TextLabel.Size                  = UDim2.new(1, 0, 1, 0)
        TextLabel.BackgroundTransparency = 1
        TextLabel.TextScaled            = false
        TextLabel.TextSize              = 13
        TextLabel.Font                  = Enum.Font.GothamSemibold
        TextLabel.TextStrokeTransparency = 0
        TextLabel.TextStrokeColor3      = Color3.fromRGB(0, 0, 0)
        TextLabel.Parent                = Billboard

        -- RenderStepped
        local Camera = workspace.CurrentCamera
        local renderConn = RunService.RenderStepped:Connect(function()
            if not State.ESP then
                LineFrame.Visible = false
                return
            end

            local hrp    = character:FindFirstChild("HumanoidRootPart")
            local myChar = LocalPlayer.Character
            local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
            if not hrp or not myHRP then
                LineFrame.Visible = false
                return
            end

            local dist   = math.floor((myHRP.Position - hrp.Position).Magnitude)
            local weapon = GetWeaponName(character)
            local seeker = IsSeeker(player)

            -- Text
            if seeker then
                TextLabel.Text = weapon
                    and string.format("%s\n%d studs\nPENCARI [%s]", player.Name, dist, weapon)
                    or  string.format("%s\n%d studs\nPENCARI", player.Name, dist)
                TextLabel.TextColor3 = Color3.fromRGB(255, 60, 60)
                Highlight.FillColor  = Color3.fromRGB(255, 0, 0)
            else
                if weapon then
                    TextLabel.Text       = string.format("%s\n%d studs\n[%s]", player.Name, dist, weapon)
                    TextLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
                    Highlight.FillColor  = Color3.fromRGB(255, 150, 0)
                else
                    TextLabel.Text       = string.format("%s\n%d studs", player.Name, dist)
                    TextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    Highlight.FillColor  = Color3.fromRGB(255, 0, 100)
                end
            end

            -- ESP Line (dari bawah layar ke posisi player)
            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local vp = Camera.ViewportSize
            local bottomCenter = Vector2.new(vp.X / 2, vp.Y)
            local targetPos    = Vector2.new(screenPos.X, screenPos.Y)

            if onScreen and screenPos.Z > 0 then
                LineFrame.Visible = true
                local dx = targetPos.X - bottomCenter.X
                local dy = targetPos.Y - bottomCenter.Y
                local len = math.sqrt(dx*dx + dy*dy)
                local ang = math.atan2(dy, dx)
                LineFrame.Size     = UDim2.new(0, len, 0, 2)
                LineFrame.Position = UDim2.new(
                    0, bottomCenter.X,
                    0, bottomCenter.Y
                )
                LineFrame.Rotation = math.deg(ang)
                LineFrame.BackgroundColor3 = seeker
                    and Color3.fromRGB(255, 60, 60)
                    or  Color3.fromRGB(255, 255, 0)
            else
                LineFrame.Visible = false
            end
        end)
        table.insert(conns, renderConn)

        -- Cleanup on character removing
        local removeConn = player.CharacterRemoving:Connect(function()
            CleanESP(player)
        end)
        table.insert(conns, removeConn)

        ESPConnections[player.Name] = conns
        ESPObjects[player.Name]     = objs
    end

    -- Apply sekarang
    if player.Character then
        task.spawn(applyToChar, player.Character)
    end

    -- Apply saat respawn / join baru
    local addedConn = player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        applyToChar(char)
    end)

    if not ESPConnections[player.Name] then
        ESPConnections[player.Name] = {}
    end
    table.insert(ESPConnections[player.Name], addedConn)
end

local function EnableAllESP()
    for _, p in pairs(Players:GetPlayers()) do
        CreateESP(p)
    end
end

local function DisableAllESP()
    for _, p in pairs(Players:GetPlayers()) do
        CleanESP(p)
    end
end

